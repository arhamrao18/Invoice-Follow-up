    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = Array.isArray($json) ? $json[0] : $json;\nlet rawText = item?.content?.parts?.[0]?.text;\n\nif (!rawText) {\n  return {\n    json: {\n      ...($('If').item.json),\n      subject: \"Payment reminder\",\n      body: \"Automatic email generation failed. Please review manually.\"\n    }\n  };\n}\n\nrawText = rawText.replace(/```json|```/g, \"\").trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(rawText);\n} catch (e) {\n  parsed = {\n    subject: \"Payment reminder\",\n    body: \"There was an issue generating this email automatically. Please review manually.\"\n  };\n}\n\nreturn {\n  json: {\n    ...($('If').item.json),\n    subject: parsed.subject,\n    body: parsed.body\n  }\n};"
      },
